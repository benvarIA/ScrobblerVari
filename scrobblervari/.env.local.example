VITE_LASTFM_API_KEY=your_api_key_here
VITE_LASTFM_SECRET=your_secret_here
PORT=3006

# Script clean.mjs (auth directe sans navigateur)
LASTFM_USERNAME=your_lastfm_username
LASTFM_PASSWORD=your_lastfm_password

# Optionnel — import playlist Spotify
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Ameliorator — remontées in-app
VITE_AMELIORATOR_URL=http://localhost:3010
VITE_AMELIORATOR_API_KEY=your_ameliorator_api_key
